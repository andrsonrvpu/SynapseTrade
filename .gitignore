mobile/ios/Flutter/app.flx

# ── Backend ──
backend/__pycache__/
backend/.env
backend/venv/
*.pyc

# ── IDE ──
.idea/
.vscode/
*.iml
*.swp

# ── OS ──
.DS_Store
Thumbs.db
desktop.ini

